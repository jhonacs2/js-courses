---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/course/Sidebar.astro';
import LessonNav from '../components/course/LessonNav.astro';

interface Lesson {
  slug: string;
  title: string;
  duration: string;
  type: string;
  order: number;
}

interface Section {
  slug: string;
  title: string;
  order: number;
  color: string;
  lessons: Lesson[];
}

interface LessonRef {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  courseSlug: string;
  courseTitle: string;
  sections: Section[];
  currentSection: string;
  currentLesson: string;
  lessonTitle: string;
  lessonDuration: string;
  lessonType: string;
  sectionTitle: string;
  sectionColor: string;
  prev?: LessonRef;
  next?: LessonRef;
}

const {
  title,
  description,
  courseSlug,
  courseTitle,
  sections,
  currentSection,
  currentLesson,
  lessonTitle,
  lessonDuration,
  lessonType,
  sectionTitle,
  sectionColor,
  prev,
  next,
} = Astro.props;

const typeLabels: Record<string, string> = {
  theory: 'Teoría',
  practice: 'Práctica',
  challenge: 'Desafío',
  setup: 'Configuración',
  reading: 'Lectura',
  tool: 'Herramienta',
  skill: 'Habilidad',
};

const typeColors: Record<string, string> = {
  theory: 'var(--azul-gatuno)',
  practice: '#22c55e',
  challenge: '#f59e0b',
  setup: '#8A8A9A',
  reading: '#6366f1',
  tool: '#14b8a6',
  skill: '#ec4899',
};
---

<BaseLayout title={`${title} — ${courseTitle}`} description={description}>
  <div class="flex min-h-screen">
    <Sidebar
      courseSlug={courseSlug}
      courseTitle={courseTitle}
      sections={sections}
      currentSection={currentSection}
      currentLesson={currentLesson}
    />

    <div class="flex-1 flex flex-col" style="margin-left: var(--sidebar-width);">
      <header class="sticky top-0 z-20 px-8 py-3 flex items-center gap-2 text-sm" style="background: var(--bg-primary); border-bottom: 1px solid var(--border);">
        <a href="/" style="color: var(--text-muted); text-decoration: none;" onmouseover="this.style.color='var(--azul-gatuno)'" onmouseout="this.style.color='var(--text-muted)'">Inicio</a>
        <span style="color: var(--text-muted);">›</span>
        <a href={`/${courseSlug}`} style="color: var(--text-muted); text-decoration: none;" onmouseover="this.style.color='var(--azul-gatuno)'" onmouseout="this.style.color='var(--text-muted)'">{courseTitle}</a>
        <span style="color: var(--text-muted);">›</span>
        <span style="color: var(--text-secondary);">{sectionTitle}</span>
        <span style="color: var(--text-muted);">›</span>
        <span style="color: var(--text-primary); font-weight: 500;" class="truncate max-w-xs">{lessonTitle}</span>
      </header>

      <main class="flex-1 px-8 md:px-12 py-10 max-w-4xl w-full mx-auto">
        <div class="mb-8">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold"
              style={`background: ${sectionColor}20; color: ${sectionColor}; font-family: var(--font-heading);`}>
              {sectionTitle}
            </span>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold"
              style={`background: ${typeColors[lessonType] || 'var(--bg-tertiary)'}15; color: ${typeColors[lessonType] || 'var(--text-muted)'}; font-family: var(--font-heading);`}>
              {typeLabels[lessonType] || lessonType}
            </span>
            <span style="font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-heading);">⏱ {lessonDuration}</span>
          </div>

          <h1 style="font-family: var(--font-display); font-size: clamp(1.75rem, 4vw, 2.5rem); color: var(--text-primary); margin: 0 0 0.5rem; line-height: 1.1; letter-spacing: 0.02em;">
            {lessonTitle}
          </h1>
          {description && (
            <p style="font-size: 1rem; color: var(--text-secondary); margin: 0; line-height: 1.6; max-width: 60ch;">
              {description}
            </p>
          )}
        </div>

        <div class="prose">
          <slot />
        </div>

        <div class="mt-8 pt-6" style="border-top: 1px solid var(--border);">
          <button
            id="complete-btn"
            onclick={`markComplete('${currentSection}/${currentLesson}')`}
            class="flex items-center gap-2 px-4 py-2 rounded-lg font-semibold text-sm transition-all duration-150"
            style="background: var(--bg-secondary); border: 1.5px solid var(--border); color: var(--text-secondary); font-family: var(--font-heading); cursor: pointer;"
          >
            <span id="complete-icon">○</span>
            <span id="complete-text">Marcar como completada</span>
          </button>
        </div>

        <LessonNav prev={prev} next={next} />
      </main>

      <footer class="px-8 py-4 text-center" style="border-top: 1px solid var(--border); background: var(--bg-secondary);">
        <p style="font-size: 0.75rem; color: var(--text-muted); margin: 0; font-family: var(--font-heading);">
          Code Cats Studios · Aprende desarrollo web con cursos prácticos
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>

<script>
  function markComplete(lessonId: string) {
    const completed: string[] = JSON.parse(localStorage.getItem('gatuno-completed') || '[]');
    const btn = document.getElementById('complete-btn');
    const icon = document.getElementById('complete-icon');
    const text = document.getElementById('complete-text');

    if (completed.includes(lessonId)) {
      const updated = completed.filter((id: string) => id !== lessonId);
      localStorage.setItem('gatuno-completed', JSON.stringify(updated));
      if (btn) { btn.style.background = 'var(--bg-secondary)'; btn.style.borderColor = 'var(--border)'; btn.style.color = 'var(--text-secondary)'; }
      if (icon) icon.textContent = '○';
      if (text) text.textContent = 'Marcar como completada';
    } else {
      completed.push(lessonId);
      localStorage.setItem('gatuno-completed', JSON.stringify(completed));
      if (btn) { btn.style.background = 'var(--success)'; btn.style.borderColor = 'var(--success)'; btn.style.color = 'white'; }
      if (icon) icon.textContent = '✓';
      if (text) text.textContent = '¡Lección completada!';
    }
    document.dispatchEvent(new CustomEvent('lesson-completed'));
  }

  document.addEventListener('DOMContentLoaded', () => {
    const path = window.location.pathname;
    const parts = path.split('/').filter(Boolean);
    if (parts.length >= 3) {
      const lessonId = `${parts[parts.length - 2]}/${parts[parts.length - 1]}`;
      const completed = JSON.parse(localStorage.getItem('gatuno-completed') || '[]');
      if (completed.includes(lessonId)) {
        const btn = document.getElementById('complete-btn');
        const icon = document.getElementById('complete-icon');
        const text = document.getElementById('complete-text');
        if (btn) { btn.style.background = 'var(--success)'; btn.style.borderColor = 'var(--success)'; btn.style.color = 'white'; }
        if (icon) icon.textContent = '✓';
        if (text) text.textContent = '¡Lección completada!';
      }
    }
  });

  (window as any).markComplete = markComplete;
</script>

<style>
  @media (max-width: 768px) {
    div[style*="margin-left: var(--sidebar-width)"] {
      margin-left: 0 !important;
    }
  }
</style>
