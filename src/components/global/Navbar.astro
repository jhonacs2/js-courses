---
interface Props {
  courseName?: string;
}

const { courseName } = Astro.props;
---

<nav style="background: var(--bg-primary); border-bottom: 1px solid var(--border);" class="sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 no-underline group">
      <img
        src="/images/mascot/cat-peek.png"
        alt="Code Cats mascota"
        class="h-9 w-auto"
      />
      <span style="font-family: var(--font-display); font-size: 1.5rem; color: var(--text-primary); letter-spacing: 0.05em;">
        Code Cats
      </span>
    </a>

    {courseName && (
      <span style="color: var(--text-muted); font-size: 0.875rem; font-family: var(--font-heading);">
        {courseName}
      </span>
    )}
  </div>
</nav>
