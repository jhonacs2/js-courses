---
interface LessonRef {
  title: string;
  href: string;
}

interface Props {
  prev?: LessonRef;
  next?: LessonRef;
}

const { prev, next } = Astro.props;
---

<nav class="flex items-stretch gap-4 mt-12 pt-8" style="border-top: 1px solid var(--border);">
  {prev ? (
    <a
      href={prev.href}
      class="flex-1 flex flex-col gap-1 p-4 rounded-xl no-underline transition-all duration-150 group"
      style="border: 1.5px solid var(--border); text-decoration: none;"
      onmouseover="this.style.borderColor='var(--azul-gatuno)'; this.style.background='var(--bg-accent-soft)'"
      onmouseout="this.style.borderColor='var(--border)'; this.style.background=''"
    >
      <span style="font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-heading);">← Anterior</span>
      <span style="font-family: var(--font-heading); font-size: 0.9rem; font-weight: 600; color: var(--azul-gatuno);" class="line-clamp-2">
        {prev.title}
      </span>
    </a>
  ) : <div class="flex-1" />}

  {next ? (
    <a
      href={next.href}
      class="flex-1 flex flex-col gap-1 p-4 rounded-xl no-underline transition-all duration-150 text-right"
      style="border: 1.5px solid var(--border); text-decoration: none;"
      onmouseover="this.style.borderColor='var(--azul-gatuno)'; this.style.background='var(--bg-accent-soft)'"
      onmouseout="this.style.borderColor='var(--border)'; this.style.background=''"
    >
      <span style="font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-heading);">Siguiente →</span>
      <span style="font-family: var(--font-heading); font-size: 0.9rem; font-weight: 600; color: var(--azul-gatuno);" class="line-clamp-2">
        {next.title}
      </span>
    </a>
  ) : <div class="flex-1" />}
</nav>
