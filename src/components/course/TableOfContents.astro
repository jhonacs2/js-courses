---
interface Lesson {
  slug: string;
  title: string;
  duration: string;
  type: string;
  order: number;
}

interface Section {
  slug: string;
  title: string;
  order: number;
  color: string;
  duration: string;
  lessons: Lesson[];
}

interface Props {
  courseSlug: string;
  sections: Section[];
}

const { courseSlug, sections } = Astro.props;

const typeIcons: Record<string, string> = {
  theory: '📖',
  practice: '💻',
  challenge: '🏆',
  setup: '⚙️',
  reading: '📄',
  tool: '🔧',
  skill: '🎯',
};
---

<div class="space-y-6">
  {sections.map((section) => (
    <div class="rounded-2xl overflow-hidden" style={`border: 1.5px solid ${section.color}30;`}>
      <div class="px-6 py-4 flex items-center gap-4" style={`background: ${section.color}10;`}>
        <div class="w-9 h-9 rounded-full flex items-center justify-center text-white font-bold flex-shrink-0"
          style={`background: ${section.color}; font-family: var(--font-heading); font-size: 0.9rem;`}>
          {section.order}
        </div>
        <div class="flex-1">
          <h3 style={`font-family: var(--font-heading); font-size: 1.0625rem; font-weight: 700; color: ${section.color}; margin: 0;`}>
            {section.title}
          </h3>
          <p style="font-size: 0.75rem; color: var(--text-muted); margin: 0; font-family: var(--font-heading);">
            {section.lessons.length} lecciones · {section.duration}
          </p>
        </div>
      </div>

      <ul class="m-0 p-0 list-none divide-y" style="border-top: 1px solid var(--border);">
        {section.lessons.map((lesson) => (
          <li>
            <a
              href={`/${courseSlug}/${section.slug}/${lesson.slug}`}
              class="flex items-center gap-3 px-6 py-3 no-underline transition-colors duration-150"
              style="color: var(--text-secondary); text-decoration: none;"
              onmouseover="this.style.background='var(--bg-secondary)'; this.style.color='var(--azul-gatuno)'"
              onmouseout="this.style.background=''; this.style.color='var(--text-secondary)'"
            >
              <span style="font-size: 0.8125rem; flex-shrink-0; color: var(--text-muted);">
                {lesson.order}.
              </span>
              <span style="font-size: 0.8125rem; flex-shrink-0;">
                {typeIcons[lesson.type] || '📖'}
              </span>
              <span style="flex: 1; font-size: 0.875rem; font-family: var(--font-body);">
                {lesson.title}
              </span>
              <span style="font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-heading); flex-shrink-0;">
                {lesson.duration}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
