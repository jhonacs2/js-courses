---
import { getCollection, getEntry } from 'astro:content';
import CourseLayout from '../../layouts/CourseLayout.astro';
import TableOfContents from '../../components/course/TableOfContents.astro';
import Instructors from '../../components/course/Instructors.astro';
import Footer from '../../components/global/Footer.astro';
import { getCourseSections } from '../../lib/courses';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map(course => ({
    params: { course: course.id },
  }));
}

const { course: courseSlug } = Astro.params;
const courseEntry = await getEntry('courses', courseSlug!);
if (!courseEntry) return Astro.redirect('/');

const course = courseEntry.data;
const sections = await getCourseSections(courseSlug!);

const mascotSrc = `/images/mascot/${course.mascotImage}.png`;

const schedule = [
  { week: '1', content: 'Fundamentos HTML + Primeros Estilos', instructor: 'Jhona' },
  { week: '2', content: 'CSS Intermedio & Box Model', instructor: 'Jhona' },
  { week: '3', content: 'Flexbox Completo', instructor: 'Jhona' },
  { week: '4', content: 'HTML Semántico & Posicionamiento', instructor: 'Arturo' },
  { week: '5', content: 'CSS Grid', instructor: 'Arturo' },
  { week: '6', content: 'Proyecto Final Integrador', instructor: 'Instructor C' },
];
---

<CourseLayout title={course.title} description={course.description} courseName={course.title}>
  <div style="background: var(--bg-primary); border-bottom: 1px solid var(--border);">
    <div class="max-w-5xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center gap-10">
      <div class="flex-1">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-2.5 py-1 rounded-full text-xs font-semibold"
            style="background: var(--verde-limon); color: var(--text-primary); font-family: var(--font-heading);">
            {course.level}
          </span>
          <span class="px-2.5 py-1 rounded-full text-xs font-semibold"
            style="background: var(--bg-tertiary); color: var(--text-secondary); font-family: var(--font-heading);">
            {course.duration}
          </span>
          <span class="px-2.5 py-1 rounded-full text-xs font-semibold"
            style="background: var(--bg-tertiary); color: var(--text-secondary); font-family: var(--font-heading);">
            {course.lessons} lecciones · {course.sections} secciones
          </span>
        </div>

        <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); color: var(--text-primary); margin: 0 0 0.75rem; line-height: 1.05; letter-spacing: 0.02em;">
          {course.title}
        </h1>
        <p style="font-size: 1.125rem; color: var(--text-secondary); margin: 0 0 1.5rem; line-height: 1.6; max-width: 50ch;">
          {course.description}
        </p>

        {course.comingSoon ? (
          <div class="flex items-center gap-3 flex-wrap">
            <span
              class="inline-flex items-center gap-2 px-4 py-3 rounded-xl text-sm font-semibold"
              style="background: var(--bg-tertiary); color: var(--text-muted); font-family: var(--font-heading); border: 1.5px dashed var(--border-hover);"
            >
              🔔 Próximamente
            </span>
            {course.startDate && (
              <span
                class="inline-flex items-center gap-2 px-4 py-3 rounded-xl text-sm font-semibold"
                style="background: var(--bg-accent-soft); color: var(--azul-gatuno); font-family: var(--font-heading);"
              >
                📅 Inicio: {course.startDate}
              </span>
            )}
          </div>
        ) : sections.length > 0 && sections[0].lessons.length > 0 && (
          <a
            href={`/${courseSlug}/${sections[0].slug}/${sections[0].lessons[0].slug}`}
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--azul-gatuno); color: white; font-family: var(--font-heading); font-weight: 600; padding: 0.875rem 1.75rem; border-radius: 0.625rem; text-decoration: none; font-size: 0.9375rem;"
            onmouseover="this.style.opacity='0.9'"
            onmouseout="this.style.opacity='1'"
          >
            Comenzar el curso →
          </a>
        )}
      </div>

      <div class="flex-shrink-0">
        <div class="w-52 h-52 rounded-2xl flex items-center justify-center"
          style={`background: linear-gradient(135deg, ${course.accentColor}20, ${course.accentColor}05); border: 1.5px solid ${course.accentColor}30;`}>
          <img src={mascotSrc} alt={course.title} class="w-44 h-44 object-contain" />
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-1 w-6 rounded-full" style="background: var(--verde-limon);"></div>
          <h2 style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 700; margin: 0; color: var(--text-primary);">
            Contenido del curso
          </h2>
        </div>
        <TableOfContents courseSlug={courseSlug!} sections={sections} />
      </div>

      <div class="space-y-6">
        <div class="rounded-xl p-5" style="background: var(--bg-secondary); border: 1.5px solid var(--border);">
          <h3 style="font-family: var(--font-heading); font-size: 0.9375rem; font-weight: 700; margin: 0 0 1rem; color: var(--text-primary);">
            📅 Cronograma (6 semanas)
          </h3>
          <div class="space-y-3">
            {schedule.map(item => (
              <div class="flex gap-3">
                <span class="flex-shrink-0 w-16 text-xs font-bold py-1 px-2 rounded-md text-center"
                  style="background: var(--verde-limon); color: var(--text-primary); font-family: var(--font-heading);">
                  Sem. {item.week}
                </span>
                <div>
                  <span style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.4;">{item.content}</span>
                  <span style="font-size: 0.6875rem; color: var(--text-muted); display: block; font-family: var(--font-heading);">— {item.instructor}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-xl p-5" style="background: var(--bg-accent-soft); border: 1.5px solid var(--azul-gatuno)30;">
          <h3 style="font-family: var(--font-heading); font-size: 0.9375rem; font-weight: 700; margin: 0 0 0.75rem; color: var(--azul-gatuno);">
            ✨ Qué aprenderás
          </h3>
          <ul class="m-0 p-0 list-none space-y-2">
            {[
              'HTML semántico y accesible',
              'CSS desde cero hasta positioning',
              'Flexbox para layouts 1D',
              'CSS Grid para layouts 2D',
              'Buenas prácticas del mundo real',
              'Herramientas de desarrollo',
            ].map(item => (
              <li class="flex items-start gap-2" style="font-size: 0.875rem; color: var(--text-secondary);">
                <span style="color: var(--azul-gatuno); font-weight: bold; flex-shrink: 0;">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  {course.instructors && course.instructors.length > 0 && (
    <div class="max-w-5xl mx-auto px-6">
      <Instructors instructors={course.instructors} />
    </div>
  )}

  <Footer />
</CourseLayout>
