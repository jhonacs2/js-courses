---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/global/Navbar.astro';
---

<BaseLayout title="404" description="Página no encontrada">
  <Navbar />

  <main class="min-h-[calc(100vh-72px)] px-6 py-16 flex items-center justify-center" style="background: var(--bg-secondary);">
    <section class="w-full max-w-2xl rounded-3xl p-8 md:p-12 text-center" style="background: var(--bg-primary); border: 1px solid var(--border);">
      <p style="font-family: var(--font-heading); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin: 0 0 0.75rem;">
        Error de navegación
      </p>

      <h1 style="font-family: var(--font-display); font-size: clamp(3.5rem, 9vw, 6rem); line-height: 1; margin: 0; color: var(--azul-gatuno);">
        404
      </h1>

      <div class="flex justify-center my-6">
        <img 
          src="/animacion/gato404.webp" 
          alt="Gato animado confundido" 
          class="w-48 h-48 md:w-64 md:h-64 object-contain"
          style="max-width: 100%;"
        />
      </div>

      <h2 style="font-family: var(--font-heading); font-size: 1.5rem; margin: 0.5rem 0 0.75rem; color: var(--text-primary);">
        Página no encontrada
      </h2>

      <p style="font-size: 1rem; color: var(--text-secondary); margin: 0 auto 1.75rem; max-width: 38ch; line-height: 1.7;">
        La ruta que abriste no existe o fue movida.
      </p>

      <a
        href="/"
        class="inline-flex items-center justify-center rounded-xl px-5 py-3"
        style="font-family: var(--font-heading); font-weight: 700; text-decoration: none; color: var(--text-primary); background: var(--verde-limon); border: 1px solid transparent;"
      >
        Volver al inicio
      </a>
    </section>
  </main>
</BaseLayout>
